{
  "name": "ereque",
  "version": "1.0.0",
  "description": "three.js wrapper (ereque, երեք)",
  "author": {
    "name": "Hayk Hakobyan",
    "email": "haykh.astro@gmail.com",
    "url": "https://haykh.github.io/tilde/"
  },
  "license": "GPL-3.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./examples": {
      "types": "./dist/examples/index.d.ts",
      "import": "./dist/examples/index.js"
    },
    "./examples/*": {
      "types": "./dist/examples/*.d.ts",
      "import": "./dist/examples/*.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint ."
  },
  "keywords": [
    "three",
    "threejs",
    "webgl",
    "gpgpu",
    "engine"
  ],
  "peerDependencies": {
    "three": ">=0.180.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fsouza/prettierd": "^0.28.0",
    "@types/node": "^26.1.1",
    "@types/three": "^0.181.0",
    "eslint": "^10.6.0",
    "eslint_d": "^14.3.0",
    "globals": "^17.7.0",
    "three": "^0.180.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.2.4",
    "vite-plugin-glsl": "^1.5.4"
  },
  "dependencies": {
    "three-mesh-bvh": "^0.9.10"
  }
}
