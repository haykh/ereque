{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "paths": {
      "ereque": ["./src/index.ts"],
      "ereque/examples": ["./src/examples/index.ts"],
      "ereque/examples/*": ["./src/examples/*"]
    }
  },
  "include": ["src", "dev"]
}
